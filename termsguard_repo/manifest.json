{
  "manifest_version": 3,
  "name": "Terms Guard — Before You Sign Up",
  "version": "1.0.1",
  "description": "Catch the fine print before you sign up: auto-renewal, refund limits, cancellation traps & hidden fees. 100% local.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Terms Guard",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "detectors.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
